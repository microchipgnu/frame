{
  "name": "@frames-ag/frame",
  "version": "0.0.2",
  "type": "module",
  "description": "The open format for live, evidence-backed datasets — protocol, CLI, and curation MCP server.",
  "license": "MIT",
  "homepage": "https://github.com/frames-ag/frame#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/frames-ag/frame.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "dataset",
    "curation",
    "evidence",
    "ndjson",
    "agents",
    "claude",
    "opencode",
    "frame"
  ],
  "main": "./dist/frame.js",
  "types": "./dist/frame.d.ts",
  "exports": {
    ".": {
      "types": "./dist/frame.d.ts",
      "import": "./dist/frame.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./mcp": {
      "types": "./dist/mcp/server.d.ts",
      "import": "./dist/mcp/server.js"
    }
  },
  "bin": {
    "frame": "./dist/cli/index.js"
  },
  "files": [
    "dist/",
    "PROTOCOL.md",
    "MCP.md",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "frame": "bun src/cli/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "test": "bun test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^12.9.0",
    "yaml": "^2.5.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
